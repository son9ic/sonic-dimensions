<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Sonic Dimensions - Title Screen</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        overflow:hidden;
        background:linear-gradient(to bottom,#001b44,#0047ab,#00a2ff);
        height:100vh;
        color:white;
    }

    /* Animated background */
    .bg{
        position:absolute;
        width:100%;
        height:100%;
        background:
        radial-gradient(circle at center, rgba(255,255,255,0.15), transparent 60%);
        animation:bgMove 8s infinite alternate;
    }

    @keyframes bgMove{
        from{
            transform:scale(1);
        }
        to{
            transform:scale(1.1);
        }
    }

    .container{
        position:relative;
        z-index:2;
        display:flex;
        flex-direction:column;
        justify-content:center;
        align-items:center;
        height:100vh;
        text-align:center;
    }

    .title{
        font-size:70px;
        font-weight:bold;
        text-shadow:0 0 20px cyan;
        margin-bottom:10px;
    }

    .subtitle{
        font-size:22px;
        margin-bottom:30px;
        opacity:0.9;
    }

    /* Sonic timeline images */
    .sonic-row{
        display:flex;
        gap:20px;
        margin-bottom:40px;
        flex-wrap:wrap;
        justify-content:center;
    }

    .sonic-card{
        width:120px;
        height:120px;
        background:rgba(255,255,255,0.12);
        border:2px solid rgba(255,255,255,0.25);
        border-radius:20px;
        backdrop-filter:blur(4px);
        display:flex;
        justify-content:center;
        align-items:center;
        flex-direction:column;
        transition:0.3s;
    }

    .sonic-card:hover{
        transform:scale(1.08);
        box-shadow:0 0 15px cyan;
    }

    .sonic-card img{
        width:80px;
        height:80px;
        object-fit:contain;
    }

    .sonic-card span{
        font-size:12px;
        margin-top:5px;
    }

    .menu{
        display:flex;
        gap:20px;
    }

    button{
        padding:15px 40px;
        font-size:24px;
        border:none;
        border-radius:15px;
        cursor:pointer;
        transition:0.25s;
        font-weight:bold;
    }

    .play-btn{
        background:#00c3ff;
        color:white;
    }

    .settings-btn{
        background:#222;
        color:white;
    }

    button:hover{
        transform:scale(1.05);
        box-shadow:0 0 15px rgba(255,255,255,0.5);
    }

    /* Settings menu */
    .settings-panel{
        position:fixed;
        top:50%;
        left:50%;
        transform:translate(-50%,-50%);
        background:rgba(0,0,0,0.9);
        padding:30px;
        border-radius:20px;
        display:none;
        width:320px;
        z-index:5;
    }

    .settings-panel h2{
        margin-bottom:20px;
    }

    .graphics-label{
        margin-top:15px;
        margin-bottom:10px;
    }

    input[type=range]{
        width:100%;
    }

    .close-btn{
        margin-top:20px;
        width:100%;
        background:#ff4444;
        color:white;
    }

    .footer{
        position:absolute;
        bottom:15px;
        width:100%;
        text-align:center;
        font-size:14px;
        opacity:0.7;
    }

    /* Chromebook optimization */
    @media(max-width:700px){
        .title{
            font-size:48px;
        }

        .sonic-card{
            width:90px;
            height:90px;
        }

        .sonic-card img{
            width:55px;
            height:55px;
        }
    }
</style>
</head>

<body>

<div class="bg"></div>

<div class="container">

    <div class="title">SONIC DIMENSIONS</div>
    <div class="subtitle">
        Journey Through Every Sonic Era
    </div>

    <!-- Sonic Versions -->
    <div class="sonic-row">

        <!-- Replace image paths later -->

        <div class="sonic-card">
            <img src="images/sa1-sonic.png" alt="SA1 Sonic">
            <span>Adventure</span>
        </div>

        <div class="sonic-card">
            <img src="images/sa2-sonic.png" alt="SA2 Sonic">
            <span>Adventure 2</span>
        </div>

        <div class="sonic-card">
            <img src="images/heroes-sonic.png" alt="Heroes Sonic">
            <span>Heroes</span>
        </div>

        <div class="sonic-card">
            <img src="images/unleashed-sonic.png" alt="Unleashed Sonic">
            <span>Unleashed</span>
        </div>

        <div class="sonic-card">
            <img src="images/modern-sonic.png" alt="Modern Sonic">
            <span>Modern</span>
        </div>

    </div>

    <!-- Buttons -->
    <div class="menu">
        <button class="play-btn" onclick="startGame()">PLAY</button>
        <button class="settings-btn" onclick="openSettings()">SETTINGS</button>
    </div>

</div>

<!-- SETTINGS -->
<div class="settings-panel" id="settingsPanel">

    <h2>Graphics Settings</h2>

    <div class="graphics-label">
        Graphics Quality
    </div>

    <input
        type="range"
        min="1"
        max="3"
        value="2"
        id="graphicsSlider"
    >

    <p id="graphicsText">
        Normal Graphics
    </p>

    <button class="close-btn" onclick="closeSettings()">
        Close
    </button>

</div>

<div class="footer">
    Sonic Dimensions © Fan Project
</div>

<script>

    const slider = document.getElementById("graphicsSlider");
    const text = document.getElementById("graphicsText");

    slider.addEventListener("input", () => {

        if(slider.value == 1){
            text.innerHTML = "Low Graphics (Best Performance)";
            document.body.style.filter = "none";
        }

        if(slider.value == 2){
            text.innerHTML = "Normal Graphics";
            document.body.style.filter = "contrast(1.05)";
        }

        if(slider.value == 3){
            text.innerHTML =
            "Ultra Graphics (May Lag on Chromebooks)";
            document.body.style.filter =
            "contrast(1.15) saturate(1.2)";
        }

    });

    function openSettings(){
        document.getElementById("settingsPanel").style.display = "block";
    }

    function closeSettings(){
        document.getElementById("settingsPanel").style.display = "none";
    }

    function startGame(){

        // Change this later
        window.location.href = "game.html";

    }

</script>

</body>
</html>
